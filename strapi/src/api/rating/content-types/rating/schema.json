{
    "kind": "collectionType",
    "collectionName": "ratings",
    "info": {
        "singularName": "rating",
        "pluralName": "ratings",
        "displayName": "Rating",
        "description": "User ratings for trips"
    },
    "options": {
        "draftAndPublish": false
    },
    "attributes": {
        "stars": {
            "type": "integer",
            "min": 1,
            "max": 5,
            "required": true
        },
        "comment": {
            "type": "text"
        },
        "trip": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::trip.trip",
            "inversedBy": "ratings"
        },
        "rater": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "plugin::users-permissions.user"
        },
        "ratee": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "plugin::users-permissions.user"
        }
    }
}