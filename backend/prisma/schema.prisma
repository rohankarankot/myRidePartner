// --- 00-base.prisma ---
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  men
  women
}

enum GenderPreference {
  men
  women
  both
}

enum TripStatus {
  PUBLISHED
  STARTED
  COMPLETED
  CANCELLED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationType {
  JOIN_REQUEST
  TRIP_UPDATE
  SYSTEM
  TRIP_COMPLETED
  COMMUNITY_GROUP
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserAccountStatus {
  ACTIVE
  PAUSED
}

enum ReportReason {
  harassment
  fake_profile
  scam
  inappropriate
  reselling
  safety
  other
}

enum ReportSource {
  profile
  trip
  community_chat
  trip_chat
  community_group_chat
}

enum ReportTargetType {
  USER
  MESSAGE
}

enum ReportReviewStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTION_TAKEN
}

// --- 10-auth.prisma ---
model User {
  id                     Int               @id @default(autoincrement())
  username               String?
  email                  String            @unique
  provider               String?           @default("local")
  password               String?
  resetPasswordToken     String?
  confirmationToken      String?
  confirmed              Boolean           @default(false)
  blocked                Boolean           @default(false)
  role                   UserRole          @default(USER)
  accountStatus          UserAccountStatus @default(ACTIVE)
  pausedAt               DateTime?
  userProfile            UserProfile?
  createdTrips           Trip[]            @relation("TripCreator")
  joinRequests           JoinRequest[]     @relation("PassengerRequests")
  notifications          Notification[]
  ratingsGiven           Rating[]          @relation("Rater")
  ratingsReceived        Rating[]          @relation("Ratee")
  sentChatMessages       TripChatMessage[]
  sentPublicChatMessages PublicChatMessage[]
  reportsGiven           UserReport[]      @relation("Reporter")
  reportsReceived        UserReport[]      @relation("ReportedUser")
  blockedUsers           UserBlock[]       @relation("Blocker")
  blockedByUsers         UserBlock[]       @relation("BlockedUser")
  appSources             UserAppSource[]
  reportsReviewed        UserReport[]      @relation("ReportReviewedBy")
  adminAuditLogs         AdminAuditLog[]
  createdGroups          CommunityGroup[]       @relation("GroupCreator")
  groupsReviewed         CommunityGroup[]       @relation("GroupReviewedBy")
  groupMemberships       CommunityGroupMember[]
  sentGroupChatMessages  CommunityGroupMessage[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([accountStatus])
}

model AppSource {
  id             Int             @id @default(autoincrement())
  slug           String          @unique
  name           String
  isActive       Boolean         @default(true)
  userAppSources UserAppSource[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([isActive])
}

model UserAppSource {
  id          Int        @id @default(autoincrement())
  source      String
  userId      Int
  appSourceId Int?
  lastLoginAt DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  appSource   AppSource? @relation(fields: [appSourceId], references: [id], onDelete: SetNull)

  @@unique([userId, source])
  @@index([source])
  @@index([userId])
  @@index([appSourceId])
}

// --- 20-user-profile.prisma ---
model UserBlock {
  id            Int      @id @default(autoincrement())
  blockerId     Int
  blockedUserId Int
  createdAt     DateTime @default(now())
  blocker       User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("BlockedUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedUserId])
  @@index([blockerId])
  @@index([blockedUserId])
}

model UserProfile {
  id                   Int      @id @default(autoincrement())
  fullName             String?
  phoneNumber          String?
  avatar               String?
  governmentIdDocument String?
  aadhaarNumber        String?
  rating               Decimal? @db.Decimal(3, 2)
  completedTripsCount  Int      @default(0)
  ratingsCount         Int      @default(0)
  isVerified           Boolean  @default(false)
  governmentIdVerified Boolean  @default(false)
  communityConsent     Boolean  @default(false)
  gender               Gender?
  city                 String?
  pushToken            String?
  userId               Int      @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// --- 30-trips.prisma ---
model Trip {
  id                Int              @id @default(autoincrement())
  documentId        String           @unique @default(uuid())
  description       String?
  startingPoint     String
  destination       String
  date              String
  time              String
  availableSeats    Int
  city              String?
  pricePerSeat      Decimal?         @db.Decimal(10, 2)
  isPriceCalculated Boolean          @default(false)
  genderPreference  GenderPreference @default(both)
  status            TripStatus       @default(PUBLISHED)
  creatorId         Int
  creator           User             @relation("TripCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  joinRequests      JoinRequest[]
  ratings           Rating[]
  chat              TripChat?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status])
  @@index([date])
  @@index([creatorId])
  @@index([city])
  @@index([createdAt])
  @@index([city, status, date, createdAt])
}

model JoinRequest {
  id               Int               @id @default(autoincrement())
  documentId       String            @unique @default(uuid())
  status           JoinRequestStatus @default(PENDING)
  requestedSeats   Int               @default(1)
  message          String?
  sharePhoneNumber Boolean           @default(false)
  tripId           Int
  trip             Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  passengerId      Int
  passenger        User              @relation("PassengerRequests", fields: [passengerId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([tripId])
  @@index([passengerId])
}

model Rating {
  id         Int      @id @default(autoincrement())
  documentId String   @unique @default(uuid())
  stars      Int
  comment    String?
  tripId     Int
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  raterId    Int
  rater      User     @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)
  rateeId    Int
  ratee      User     @relation("Ratee", fields: [rateeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tripId, raterId])
  @@index([rateeId])
}

// --- 40-chat-notifications.prisma ---
model Notification {
