{
    "cli": {
        "version": ">= 5.9.3",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development"
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "autoIncrement": true,
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "distribution": "store",
            "channel": "production",
            "autoIncrement": true
        },
        "apk-production": {
            "extends": "production",
            "distribution": "internal",
            "channel": "production",
            "android": {
                "buildType": "apk"
            }
        }
    },
    "submit": {
        "production": {
            "releaseStatus": "draft",
            "track": "internal"
        }
    }
}
