EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_API_URL=https://your-backend-url
EXPO_PUBLIC_OLA_MAPS_API_KEY=your-ola-maps-api-key
EXPO_PUBLIC_OLA_MAPS_PROJECT_ID=your-ola-project-id
EXPO_PUBLIC_OLA_MAPS_CLIENT_ID=your-ola-client-id
OLA_MAPS_CLIENT_SECRET=your-ola-client-secret

# AdMob app IDs used by the native build config
ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~androidappid
ADMOB_IOS_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~iosappid

# AdMob ad unit IDs used in JS
EXPO_PUBLIC_ADMOB_DISCOVERY_BANNER_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/androidbannerid
EXPO_PUBLIC_ADMOB_DISCOVERY_BANNER_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/iosbannerid
