// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  men
  women
}

enum GenderPreference {
  men
  women
  both
}

enum TripStatus {
  PUBLISHED
  STARTED
  COMPLETED
  CANCELLED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationType {
  JOIN_REQUEST
  TRIP_UPDATE
  SYSTEM
  TRIP_COMPLETED
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id                 Int            @id @default(autoincrement())
  username           String?
  email              String         @unique
  provider           String?        @default("local")
  password           String?
  resetPasswordToken String?
  confirmationToken  String?
  confirmed          Boolean        @default(false)
  blocked            Boolean        @default(false)
  role               UserRole       @default(USER)

  // Relations
  userProfile        UserProfile?
  createdTrips       Trip[]         @relation("TripCreator")
  joinRequests       JoinRequest[]  @relation("PassengerRequests")
  notifications      Notification[]
  ratingsGiven       Rating[]       @relation("Rater")
  ratingsReceived    Rating[]       @relation("Ratee")
  sentChatMessages   TripChatMessage[]

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model UserProfile {
  id                   Int       @id @default(autoincrement())
  fullName             String?
  phoneNumber          String?
  avatar               String?   // URL or media reference
  rating               Decimal?  @db.Decimal(3, 2)
  completedTripsCount  Int       @default(0)
  ratingsCount         Int       @default(0)
  isVerified           Boolean   @default(false)
  governmentIdVerified Boolean   @default(false)
  gender               Gender?
  city                 String?
  pushToken            String?

  // Relations
  userId               Int       @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Trip {
  id               Int              @id @default(autoincrement())
  documentId       String           @unique @default(uuid())
  description      String?
  startingPoint    String
  destination      String
  date             String           // YYYY-MM-DD format
  time             String           // HH:mm format
  availableSeats   Int
  city             String?          // Static city name for filtering
  pricePerSeat     Decimal?         @db.Decimal(10, 2)
  isPriceCalculated Boolean         @default(false)
  genderPreference GenderPreference @default(both)
  status           TripStatus       @default(PUBLISHED)

  // Relations
  creatorId        Int
  creator          User             @relation("TripCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  joinRequests     JoinRequest[]
  ratings          Rating[]
  chat             TripChat?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status])
  @@index([date])
  @@index([creatorId])
}

model JoinRequest {
  id             Int               @id @default(autoincrement())
  documentId     String            @unique @default(uuid())
  status         JoinRequestStatus @default(PENDING)
  requestedSeats Int               @default(1)
  message        String?

  // Relations
  tripId         Int
  trip           Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  passengerId    Int
  passenger      User              @relation("PassengerRequests", fields: [passengerId], references: [id], onDelete: Cascade)

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([tripId])
  @@index([passengerId])
}

model Notification {
  id         Int              @id @default(autoincrement())
  documentId String           @unique @default(uuid())
  title      String
  message    String
  type       NotificationType
  read       Boolean          @default(false)
  data       Json?
  relatedId  String?

  // Relations
  userId     Int
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([userId])
  @@index([userId, read])
}

model Rating {
  id         Int      @id @default(autoincrement())
  documentId String   @unique @default(uuid())
  stars      Int
  comment    String?

  // Relations
  tripId     Int
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  raterId    Int
  rater      User     @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)
  rateeId    Int
  ratee      User     @relation("Ratee", fields: [rateeId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tripId, raterId])
  @@index([rateeId])
}

model TripChat {
  id         Int               @id @default(autoincrement())
  documentId String            @unique @default(uuid())

  tripId     Int               @unique
  trip       Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  messages   TripChatMessage[]

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model TripChatMessage {
  id         Int       @id @default(autoincrement())
  documentId String    @unique @default(uuid())
  message    String

  chatId     Int
  chat       TripChat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId   Int
  sender     User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([chatId, createdAt])
  @@index([senderId])
}
