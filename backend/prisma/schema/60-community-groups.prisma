enum CommunityGroupStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CommunityGroupRole {
  ADMIN
  MEMBER
}

model CommunityGroup {
  id           Int                      @id @default(autoincrement())
  documentId   String                   @unique @default(uuid())
  name         String
  description  String?
  status       CommunityGroupStatus     @default(PENDING)
  reviewedAt   DateTime?
  reviewedById Int?
  reviewedBy   User?                    @relation("GroupReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  creatorId    Int
  creator      User                     @relation("GroupCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  members      CommunityGroupMember[]
  messages     CommunityGroupMessage[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([status])
  @@index([creatorId])
}

model CommunityGroupMember {
  id        Int                @id @default(autoincrement())
  role      CommunityGroupRole @default(MEMBER)
  groupId   Int
  group     CommunityGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    Int
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
}

model CommunityGroupMessage {
  id         Int                      @id @default(autoincrement())
  documentId String                   @unique @default(uuid())
  message    String
  groupId    Int
  group      CommunityGroup           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId   Int
  sender     User                     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyToId  Int?
  replyTo    CommunityGroupMessage?   @relation("GroupMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies    CommunityGroupMessage[]  @relation("GroupMessageReplies")
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  @@index([groupId, createdAt])
  @@index([senderId])
  @@index([replyToId])
}

