// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  men
  women
}

enum GenderPreference {
  men
  women
  both
}

enum TripStatus {
  PUBLISHED
  STARTED
  COMPLETED
  CANCELLED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationType {
  JOIN_REQUEST
  TRIP_UPDATE
  SYSTEM
  TRIP_COMPLETED
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserAccountStatus {
  ACTIVE
  PAUSED
}

enum ReportReason {
  harassment
  fake_profile
  scam
  inappropriate
  reselling
  safety
  other
}

enum ReportSource {
  profile
  trip
  community_chat
  trip_chat
}

enum ReportTargetType {
  USER
  MESSAGE
}

model User {
  id                 Int            @id @default(autoincrement())
  username           String?
  email              String         @unique
  provider           String?        @default("local")
  password           String?
  resetPasswordToken String?
  confirmationToken  String?
  confirmed          Boolean        @default(false)
  blocked            Boolean        @default(false)
  role               UserRole       @default(USER)
  accountStatus      UserAccountStatus @default(ACTIVE)
  pausedAt           DateTime?

  // Relations
  userProfile        UserProfile?
  createdTrips       Trip[]         @relation("TripCreator")
  joinRequests       JoinRequest[]  @relation("PassengerRequests")
  notifications      Notification[]
  ratingsGiven       Rating[]       @relation("Rater")
  ratingsReceived    Rating[]       @relation("Ratee")
  sentChatMessages   TripChatMessage[]
  sentPublicChatMessages PublicChatMessage[]
  reportsGiven       UserReport[]   @relation("Reporter")
  reportsReceived    UserReport[]   @relation("ReportedUser")
  blockedUsers       UserBlock[]    @relation("Blocker")
  blockedByUsers     UserBlock[]    @relation("BlockedUser")
  appSources         UserAppSource[]

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([accountStatus])
}

model AppSource {
  id             Int             @id @default(autoincrement())
  slug           String          @unique
  name           String
  isActive       Boolean         @default(true)
  userAppSources UserAppSource[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([isActive])
}

model UserAppSource {
  id          Int      @id @default(autoincrement())
  source      String
  userId      Int
  appSourceId Int?
  lastLoginAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appSource   AppSource? @relation(fields: [appSourceId], references: [id], onDelete: SetNull)

  @@unique([userId, source])
  @@index([source])
  @@index([userId])
  @@index([appSourceId])
}

model UserBlock {
  id            Int      @id @default(autoincrement())
  blockerId     Int
  blockedUserId Int
  createdAt     DateTime @default(now())

  blocker       User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("BlockedUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedUserId])
  @@index([blockerId])
  @@index([blockedUserId])
}

model UserProfile {
  id                   Int       @id @default(autoincrement())
  fullName             String?
  phoneNumber          String?
  avatar               String?   // URL or media reference
  governmentIdDocument String?   // Uploaded government ID image URL
  aadhaarNumber        String?   // Extracted Aadhaar number
  rating               Decimal?  @db.Decimal(3, 2)
  completedTripsCount  Int       @default(0)
  ratingsCount         Int       @default(0)
  isVerified           Boolean   @default(false)
  governmentIdVerified Boolean   @default(false)
  communityConsent     Boolean   @default(false)
  gender               Gender?
  city                 String?
  pushToken            String?

  // Relations
  userId               Int       @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Trip {
  id               Int              @id @default(autoincrement())
  documentId       String           @unique @default(uuid())
  description      String?
  startingPoint    String
  destination      String
  date             String           // YYYY-MM-DD format
  time             String           // HH:mm format
  availableSeats   Int
  city             String?          // Static city name for filtering
  pricePerSeat     Decimal?         @db.Decimal(10, 2)
  isPriceCalculated Boolean         @default(false)
  genderPreference GenderPreference @default(both)
  status           TripStatus       @default(PUBLISHED)

  // Relations
  creatorId        Int
  creator          User             @relation("TripCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  joinRequests     JoinRequest[]
  ratings          Rating[]
  chat             TripChat?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status])
  @@index([date])
  @@index([creatorId])
  @@index([city])
  @@index([createdAt])
  @@index([city, status, date, createdAt])
}

model JoinRequest {
  id             Int               @id @default(autoincrement())
  documentId     String            @unique @default(uuid())
  status         JoinRequestStatus @default(PENDING)
  requestedSeats Int               @default(1)
  message        String?
  sharePhoneNumber Boolean         @default(false)

  // Relations
  tripId         Int
  trip           Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  passengerId    Int
  passenger      User              @relation("PassengerRequests", fields: [passengerId], references: [id], onDelete: Cascade)

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([tripId])
  @@index([passengerId])
}

model Notification {
  id         Int              @id @default(autoincrement())
  documentId String           @unique @default(uuid())
  title      String
  message    String
  type       NotificationType
  read       Boolean          @default(false)
  data       Json?
  relatedId  String?

  // Relations
  userId     Int
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([userId])
  @@index([userId, read])
}

model Rating {
  id         Int      @id @default(autoincrement())
  documentId String   @unique @default(uuid())
  stars      Int
  comment    String?

  // Relations
  tripId     Int
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  raterId    Int
  rater      User     @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)
  rateeId    Int
  ratee      User     @relation("Ratee", fields: [rateeId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tripId, raterId])
  @@index([rateeId])
}

model TripChat {
  id         Int               @id @default(autoincrement())
  documentId String            @unique @default(uuid())

  tripId     Int               @unique
  trip       Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  messages   TripChatMessage[]

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model TripChatMessage {
  id         Int       @id @default(autoincrement())
  documentId String    @unique @default(uuid())
  message    String

  chatId     Int
  chat       TripChat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId   Int
  sender     User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyToId  Int?
  replyTo    TripChatMessage?  @relation("TripChatMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies    TripChatMessage[] @relation("TripChatMessageReplies")

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([chatId, createdAt])
  @@index([senderId])
  @@index([replyToId])
}

model PublicChatMessage {
  id         Int      @id @default(autoincrement())
  documentId String   @unique @default(uuid())
  message    String
  city       String?

  senderId   Int
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  replyToId  Int?
  replyTo    PublicChatMessage?  @relation("PublicChatMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies    PublicChatMessage[] @relation("PublicChatMessageReplies")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
  @@index([city, createdAt])
  @@index([senderId])
  @@index([replyToId])
}

model UserReport {
  id               Int          @id @default(autoincrement())
  documentId       String       @unique @default(uuid())
  reason           ReportReason
  details          String?
  source           ReportSource
  targetType       ReportTargetType @default(USER)
  tripDocumentId   String?      // optional trip context
  messageDocumentId String?
  messagePreview   String?

  reportedUserId   Int
  reportedUser     User         @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporterId       Int
  reporter         User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  createdAt        DateTime     @default(now())

  @@index([reportedUserId])
  @@index([reporterId])
  @@index([source, targetType])
  @@index([messageDocumentId])
}
